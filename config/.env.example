# ── Crypto 15-Min PolyTrader — Environment Configuration ──────────────────
# Copy this file to .env and fill in your values.
# Based on v0.6.1 with custom patches for 15-minute BTC markets.

# ── Core settings ──────────────────────────────────────────────────────────
C5_POLY_PRIVATE_KEY=your_private_key_here
C5_DASHBOARD_PASSWORD=your_password_here

# ── 15-Minute market settings ──────────────────────────────────────────────
C5_GRANULARITY_SECONDS=900
C5_SYMBOL=BTC-USD

# ── Delta-First Strategy ───────────────────────────────────────────────────
C5_DELTA_FIRST=true
C5_DELTA_PRICING=true
C5_DELTA_PRICE_T1=0.52
C5_DELTA_PRICE_T2=0.58
C5_DELTA_PRICE_T3=0.68
C5_DELTA_PRICE_T4=0.82
C5_DELTA_PRICE_T5=0.97

# ── Snipe settings (15-min windows = more time, use larger lead) ───────────
C5_SNIPE_ENABLED=true
C5_SNIPE_LEAD_SECONDS=20
C5_SNIPE_MIN_DELTA_PCT=0.025
C5_SNIPE_BET_MULTIPLIER=2.5

# ── Trade execution ────────────────────────────────────────────────────────
C5_POLY_TRADE_LEAD_SECONDS=120
C5_POLY_MAX_USDC_PER_TRADE=5.0
C5_POLY_EDGE_MIN=0.03
C5_CONFIDENCE_THRESHOLD=0.58
C5_LOOKBACK_DAYS=45
C5_RETRAIN_MINUTES=30

# ── Thin book guard (custom patch) ────────────────────────────────────────
C5_POLY_MIN_BOOK_USDC=20

# ── Market Quality (optional) ─────────────────────────────────────────────
# Helps avoid paying through wide spreads / thin liquidity.
# Set any of these to 0 to disable that specific filter.
C5_MQ_MAX_SPREAD_BPS=120
C5_MQ_MIN_DEPTH_USDC=15
C5_MQ_DEPTH_CAP_BPS=30
# Adaptive edge: adds extra required edge when spreads widen.
C5_MQ_EDGE_SPREAD_MULT=0.10

# Per-asset tuning (optional JSON)
# Example: {"BTC-USD":{"confidence_threshold":0.60,"edge_min":0.03,"mq_max_spread_bps":90,"mq_min_depth_usdc":25}}
C5_PER_ASSET_TUNING_JSON=

# ── Risk rails (circuit breakers) ────────────────────────────────────────
# Option B defaults: pause after 3 consecutive losses, auto-resume after 45 min.
# You can also set these from the Dashboard under "Risk rails".
C5_RISK_CONSEC_LOSS_LIMIT=3
C5_RISK_AUTO_RESUME_MINUTES=45

# Pause trading if 24h losses exceed this % of starting balance. 0 disables.
C5_RISK_DAILY_LOSS_PCT=10

# Pause if too many recent orders go unfilled (thin books / wide spreads).
C5_RISK_UNFILLED_RATIO=0.5
C5_RISK_UNFILLED_LOOKBACK=20

# ── Live mode ─────────────────────────────────────────────────────────────
C5_POLY_LIVE=true
C5_LOG_LEVEL=INFO
